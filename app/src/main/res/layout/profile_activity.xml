<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beigeBackground"
    tools:context=".common.ProfileActivity">

    <Button
        android:id="@+id/btn_logout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="33dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="@color/regularBlueTitle"
        android:fontFamily="@font/jost_semibolditalic"
        android:text="@string/log_out"
        android:textColor="@color/beigeBackground"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/hello_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="45dp"
        android:fontFamily="@font/jost_bold"
        android:text="@string/hello"
        android:textColor="@color/darkestBlueMainText"
        android:textSize="35sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/profile_name_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="136dp"
        android:layout_marginTop="99dp"
        android:fontFamily="@font/jost_bolditalic"
        android:padding="10dp"
        android:text=" Jane Doe"
        android:textColor="@color/regularBlueTitle"
        android:textSize="40sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/personal_info_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="200dp"
        android:background="@drawable/square_lightblue_rounded"
        android:paddingBottom="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/card_header_bg"
            android:layout_width="0dp"
            android:layout_height="43dp"
            android:background="@drawable/darkblue_rounded"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/info_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_dialog_info"
            app:layout_constraintBottom_toBottomOf="@+id/card_header_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/card_header_bg"
            app:tint="@color/beigeBackground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Personal Information"
            android:textColor="@color/beigeBackground"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="@+id/card_header_bg"
            app:layout_constraintStart_toEndOf="@+id/info_icon"
            app:layout_constraintTop_toTopOf="@+id/card_header_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@+id/card_header_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="0dp"
                android:paddingVertical="2dp"
                android:text="Name"
                android:textColor="@color/darkBlueTitle"
                android:textSize="20sp" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/profile_field_bg"
                android:enabled="false"
                android:paddingHorizontal="12dp"
                android:text="Jane"
                android:textColor="@color/darkestBlueMainText"
                android:textSize="23sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="0dp"
                android:paddingVertical="2dp"
                android:text="Last name"
                android:textColor="@color/darkBlueTitle"
                android:textSize="20sp" />

            <EditText
                android:id="@+id/et_last_name"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/profile_field_bg"
                android:enabled="false"
                android:paddingHorizontal="12dp"
                android:text="Doe"
                android:textColor="@color/darkestBlueMainText"
                android:textSize="23sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="0dp"
                android:paddingVertical="2dp"
                android:text="@string/personal_identification_document"
                android:textColor="@color/darkBlueTitle"
                android:textSize="20sp" />

            <EditText
                android:id="@+id/et_id"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/profile_field_bg"
                android:enabled="false"
                android:paddingHorizontal="12dp"
                android:text="0298398.jpg"
                android:textColor="@color/darkestBlueMainText"
                android:textSize="23sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!--
        Botons alineats verticalment sota la card:
        1. EDIT  (ja existent)
        2. UPLOAD DNI
        3. DOWNLOAD DNI
    -->
    <LinearLayout
        android:id="@+id/dni_buttons_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="vertical"
        android:spacing="8dp"
        app:layout_constraintEnd_toEndOf="@+id/personal_info_card"
        app:layout_constraintTop_toBottomOf="@+id/personal_info_card">

        <android.widget.Button
            android:id="@+id/btn_edit_save"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:paddingHorizontal="5dp"
            android:background="@drawable/btn_red_rounded"
            android:fontFamily="@font/jost_black"
            android:text="EDIT"
            android:textColor="@color/beigeBackground"
            android:textSize="18sp" />

        <android.widget.Button
            android:id="@+id/btn_upload_dni"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="5dp"
            android:background="@drawable/btn_red_rounded"
            android:fontFamily="@font/jost_black"
            android:text="UPLOAD DNI"
            android:textColor="@color/beigeBackground"
            android:textSize="18sp" />

        <android.widget.Button
            android:id="@+id/btn_download_dni"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="5dp"
            android:background="@drawable/btn_red_rounded"
            android:fontFamily="@font/jost_black"
            android:text="DOWNLOAD DNI"
            android:textColor="@color/beigeBackground"
            android:textSize="18sp" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:itemIconSize="32dp"
        app:itemIconTint="@color/white"
        app:labelVisibilityMode="unlabeled"
        android:background="@color/darkBlueButton"
        app:menu="@menu/nav_bar_bottom"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>