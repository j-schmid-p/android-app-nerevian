<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beigeBackground"
    tools:context=".client.OrderInfoActivity">

    <TextView
        android:id="@+id/tv_order_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="45dp"
        android:fontFamily="@font/jost_bold"
        android:text="Order"
        android:textColor="@color/darkestBlueMainText"
        android:textSize="35sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_order_id_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="140dp"
        android:layout_marginTop="28dp"
        android:fontFamily="@font/jost_bolditalic"
        android:padding="10dp"
        android:text="#12345"
        android:textColor="@color/regularBlueTitle"
        android:textSize="40sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintTop_toBottomOf="@id/tv_order_id_header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/order_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/square_lightblue_rounded"
            android:paddingBottom="16dp">

            <View
                android:id="@+id/card_header_bg"
                android:layout_width="0dp"
                android:layout_height="43dp"
                android:background="@drawable/darkblue_rounded"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/info_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/ic_dialog_info"
                app:layout_constraintBottom_toBottomOf="@+id/card_header_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/card_header_bg"
                app:tint="@color/beigeBackground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Order Information"
                android:textColor="@color/beigeBackground"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="@+id/card_header_bg"
                app:layout_constraintStart_toEndOf="@+id/info_icon"
                app:layout_constraintTop_toTopOf="@+id/card_header_bg" />

            <LinearLayout
                android:id="@+id/info_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@+id/card_header_bg">

                <!-- Dynamic fields will be added here or I'll define them all and toggle visibility -->

                <TextView
                    android:id="@+id/label_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_origin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Origin"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_origin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_destination"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Destination"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_destination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_cargo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cargo Type"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_cargo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_incoterm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Incoterm"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_incoterm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date Created"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_weight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gross Weight (kg)"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_weight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volume (m3)"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_volume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_transport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transport Type"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_transport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_flow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flow Type"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_flow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Container Type"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_shipping_line"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shipping Line"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_shipping_line"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/label_comments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comments"
                    android:textColor="@color/darkBlueTitle"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_comments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:background="@drawable/profile_field_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/darkestBlueMainText"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:itemIconSize="32dp"
        app:itemIconTint="@color/white"
        app:labelVisibilityMode="unlabeled"
        android:background="@color/darkBlueButton"
        app:menu="@menu/nav_bar_bottom"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>