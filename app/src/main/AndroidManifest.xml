<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nerevian">
        <activity
            android:name=".client.GameActivity"
            android:exported="false" />
        <activity
            android:name=".common.HomePageActivity"
            android:exported="true">
        </activity>
        <activity
            android:name=".client.OrderDocumentsActivity"
            android:exported="false" />
        <activity
            android:name=".agent.UpdateTrackingActivity"
            android:exported="false" />
        <activity
            android:name=".agent.OrderInfoActivity"
            android:exported="false" />
        <activity
            android:name=".agent.OrderHistoryAgentActivity"
            android:exported="false" />
        <activity
            android:name=".agent.AgentHomeFragment"
            android:exported="true" />
        <activity
            android:name=".client.ClientHomeFragment"
            android:exported="true">
        </activity>

        <activity
            android:name=".common.LoginActivity"
            android:exported="true">


            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".common.ProfileActivity"
            android:exported="false">
        </activity>
        <activity
            android:name=".client.OrderHistoryClientActivity"
            android:exported="false" />
        <activity
            android:name=".client.TrackerActivity"
            android:exported="false" />
    </application>
</manifest>